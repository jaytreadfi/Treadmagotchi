PORT=3000
HOSTNAME=127.0.0.1
# DATA_DIR defaults to ~/.local/share/treadmagotchi (macOS/Linux)
# or %LOCALAPPDATA%\treadmagotchi (Windows) — safe from iCloud sync.
# Override only if you want a custom location:
# DATA_DIR=/path/to/data
# REVERSE_PROXY=true      # enable if behind nginx/caddy (activates bearer token auth)
# API keys are configured via the web UI, not here
