{
  "name": "treadmagotchi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "pm2:start": "next build && pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop treadmagotchi",
    "pm2:restart": "pm2 restart treadmagotchi",
    "pm2:logs": "pm2 logs treadmagotchi",
    "backup": "node -e \"require('better-sqlite3')('data/treadmagotchi.db').backup('data/backup-' + new Date().toISOString().replace(/[:.]/g,'-') + '.db')\""
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.45.1",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  }
}
